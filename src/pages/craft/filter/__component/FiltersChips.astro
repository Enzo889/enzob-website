---
interface Filter {
	label: string;
	selected?: boolean;
}

interface Props {
	filters: Filter[];
}

const { filters } = Astro.props;
---

<div class="filter-group">
  {filters.map((f) => (
    <button
      class="filter-chip"
      data-selected={f.selected ? "true" : "false"}
      aria-pressed={f.selected ? "true" : "false"}
    >
      {f.label}
    </button>
  ))}
</div>

<style>
  .filter-group {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    background-color: color-mix(in srgb, var(--color-surface) 60%, transparent);
    padding: 10%; /* Ajustado desde 10% para no romperse en pantallas amplias */
    border-radius: 32px;
    isolation: isolate;
    border: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
    width: max-content;
    max-width: 100%;
    box-shadow: 0 4px 24px -8px color-mix(in srgb, var(--color-text, #000) 10%, transparent);
  }

  /* Responsive: En móviles hacemos scroll horizontal */
  @media (max-width: 640px) {
    .filter-group {
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      border-radius: 999px;
      padding: 12px;
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none;
    }
    .filter-group::-webkit-scrollbar {
      display: none; /* Chrome/Safari */
    }
  }

  .filter-chip {
    padding: 7px 16px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid color-mix(in srgb, var(--color-text, currentColor) 15%, transparent);
    background: transparent;
    color: var(--color-text-muted, #888);
    transition: all 0.2s ease;
    user-select: none;
    will-change: border-radius, margin-left, background, color;
    
    /* Evitar que se compriman en scroll horizontal */
    flex-shrink: 0;
  }

  .filter-chip:hover {
    color: var(--color-text, currentColor);
    background: color-mix(in srgb, var(--color-text, currentColor) 4%, transparent);
  }

  .filter-chip[data-selected="true"] {
    background: var(--color-accent, #111);
    color: var(--color-surface, #fff);
    border-color: var(--color-accent, transparent);
    box-shadow: inset 0px 2px 4px color-mix(in srgb, var(--color-surface, #fff) 25%, transparent);
  }

  .filter-chip[data-selected="true"] + .filter-chip[data-selected="true"] {
    margin-left: -10px;
  }

  .filter-chip:focus-visible {
    outline: 2px solid var(--color-accent, #111);
    outline-offset: 2px;
  }
</style>

<script>
  import { animate } from 'motion'

  // R = full pill radius, r = inner corner radius when adjacent chips merge
  const R = 999
  const r = 5
  const SPRING = { easing: 'spring(400, 28)' } as const
  const SPRING_BOUNCE = { easing: 'spring(280, 16)' } as const

  const group = document.querySelector<HTMLDivElement>('.filter-group')!
  const chips = Array.from(group.querySelectorAll<HTMLButtonElement>('.filter-chip'))

  function getBorderRadius(i: number): string {
    const selected = chips[i].dataset.selected === 'true'
    const prevSel = i > 0 && chips[i - 1].dataset.selected === 'true'
    const nextSel = i < chips.length - 1 && chips[i + 1].dataset.selected === 'true'

    if (!selected) return `${R}px`

    const tl = prevSel ? r : R
    const bl = prevSel ? r : R
    const tr = nextSel ? r : R
    const br = nextSel ? r : R

    return `${tl}px ${tr}px ${br}px ${bl}px`
  }

  function updateBorders(clickedIndex: number, wasSelected: boolean) {
    chips.forEach((chip, i) => {
      const target = getBorderRadius(i)
      // deselected chip gets a bouncier spring so it feels like it's popping off
      const isDeselecting = i === clickedIndex && wasSelected
      const easing = isDeselecting ? SPRING_BOUNCE : SPRING

      animate(chip, { borderRadius: target }, { duration: 0.35, ...easing })
    })
  }

  // Apply initial border-radius without animation
  chips.forEach((chip, i) => {
    chip.style.borderRadius = getBorderRadius(i)
  })

  document.addEventListener("astro:page-load", () => {
    chips.forEach((chip, i) => {
    chip.addEventListener('click', () => {
      const wasSelected = chip.dataset.selected === 'true'
      chip.dataset.selected = wasSelected ? 'false' : 'true'
      chip.setAttribute('aria-pressed', chip.dataset.selected)
      updateBorders(i, wasSelected)
    })
  })
  })
</script>