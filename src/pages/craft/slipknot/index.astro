---
import HUD from "./__components/HUD.astro";
import StatusBar from "./__components/StatusBar.astro";
import HeroSection from "./__components/HeroSection.astro";
import ParallaxSection from "./__components/ParallaxSection.astro";
import CharScrambleSection from "./__components/CharScrambleSection.astro";
import DiscographySection from "./__components/DiscographySection.astro";
import ScaleRevealSection from "./__components/ScaleRevealSection.astro";
import ClipRevealSection from "./__components/ClipRevealSection.astro";
import VelocityMarqueeSection from "./__components/VelocityMarqueeSection.astro";
import HorizontalScrollSection from "./__components/HorizontalScrollSection.astro";
import TiltCardsSection from "./__components/TiltCardsSection.astro";
import StickyCounterSection from "./__components/StickyCounterSection.astro";
import AnchorsSection from "./__components/AnchorsSection.astro";
import DirectionSection from "./__components/DirectionSection.astro";
import StopperSection from "./__components/StopperSection.astro";
import FooterSection from "./__components/FooterSection.astro";

// Specific images for parallax
import img_live1 from "./images/imgi_241_DSC_6209-Enhanced-NR-copy-2.jpg";
import img_live2 from "./images/imgi_238_@gnarlymedia_-50.jpg";
import img_solway from "./images/imgi_79_solway-1-scaled.jpg";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Slipknot × Lenis + Motion · Craft · Enzo Bustamante</title>
  <meta name="description" content="An interactive scroll experience for Slipknot built with Lenis smooth scroll and Motion v12. Parallax, velocity-driven animations, tilt effects, and more." />
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Enzo Bustamante" />
  <meta property="og:title" content="Slipknot × Lenis + Motion · Craft · Enzo Bustamante" />
  <meta property="og:description" content="An interactive scroll experience for Slipknot built with Lenis smooth scroll and Motion v12. Parallax, velocity-driven animations, tilt effects, and more." />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="Slipknot × Lenis + Motion · Craft · Enzo Bustamante" />
  <meta name="twitter:description" content="An interactive scroll experience built with Lenis smooth scroll and Motion v12." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Metal+Mania&family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;600;700&display=swap" rel="stylesheet" />
  
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --red: #c0392b; --red-bright: #e74c3c; --accent: #ff2a00;
      --dark: #0a0a0a; --darker: #050505; --grey: #111; --grey-mid: #1e1e1e;
      --text: #ddd; --text-dim: #666;
    }
    html { background: var(--darker); scroll-behavior: auto; }
    body {
      font-family: 'Barlow Condensed', sans-serif;
      background: var(--darker); color: var(--text); overflow-x: hidden;
      transform-origin: top center;
    }

    #progress-bar {
      position:fixed; top:0; left:0; height:3px; z-index:300; width:100%;
      background:linear-gradient(90deg,var(--red),var(--accent));
      box-shadow:0 0 10px var(--accent); transform-origin:left; transform:scaleX(0);
    }

    .section-tag {
      display:inline-block; font-size:.67rem; letter-spacing:.22em;
      text-transform:uppercase; color:var(--red-bright);
      border:1px solid rgba(192,57,43,.4); padding:.2rem .7rem; margin-bottom:.7rem;
    }
    .section-title {
      font-family:'Bebas Neue',sans-serif;
      font-size:clamp(2.5rem,6vw,5rem); line-height:1; color:#fff; margin-bottom:.7rem;
    }
    .section-body { font-size:1.05rem; line-height:1.7; color:var(--text-dim); font-weight:300; }
    code { color:var(--red-bright); font-size:.9em; }

    .reveal-heading { opacity:0; }
    .reveal-body    { opacity:0; }
  </style>
</head>
<body>
  <div id="progress-bar"></div>

  <HUD />
  <StatusBar />

  <HeroSection />

  <ParallaxSection
    id="s-parallax"
    imgId="para-1"
    imgSrc={img_live1.src}
    alt="Slipknot Live"
  >
    <span class="section-tag" data-enter="scale" data-enter-delay="0.1">lenis.on('scroll') — parallax</span>
    <h2 class="section-title reveal-heading" data-enter="slash">Driven by scroll</h2>
    <p class="section-body reveal-body" data-enter="up" data-enter-delay="0.2">Lenis exposes <code>scroll</code>, <code>velocity</code>, <code>direction</code> and <code>progress</code> at every frame. We push the image at a different speed than the page, creating depth.</p>
  </ParallaxSection>

  <CharScrambleSection />
  <DiscographySection />
  <ScaleRevealSection />
  <ClipRevealSection />
  <VelocityMarqueeSection />

  <section id="s-band" class="band-full">
    <img class="band-full-img" id="para-2" src={img_live2.src} alt="Slipknot band" loading="lazy" />
    <div class="band-full-overlay">
      <p class="band-quote">
        This is not a phase. This is
        <span class="accent">who we are</span>.
        This is what we do.
      </p>
    </div>
  </section>

  <HorizontalScrollSection />
  <TiltCardsSection />
  <StickyCounterSection />
  <AnchorsSection />
  <DirectionSection />
  <StopperSection />

  <ParallaxSection
    id="s-p3"
    imgId="para-3"
    imgSrc={img_solway.src}
    alt="Slipknot Solway"
    alignText="right"
  >
    <span class="section-tag" data-enter="scale" data-enter-delay="0.1">lenis.on('scroll') + progress</span>
    <h2 class="section-title reveal-heading" data-enter="slash">Infinite Noise</h2>
    <p class="section-body reveal-body" data-enter="up" data-enter-delay="0.2">Combining `Motion v12` with `Lenis` opens up endless creative possibilities. Let the scroll dictate the experience.</p>
  </ParallaxSection>

  <FooterSection />

  <script>
    import "./__components/lenis-motion";
  </script>
</body>
</html>