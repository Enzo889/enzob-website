---
import { ArrowLeft } from "@/components/icon";
import MainLayout from "@/layout/MainLayout.astro";

const crafts = [
	{
		name: "html-in-canvas experimental",
		url: "/craft/html-canvas",
		year: "2026",
	},
	{ name: "Zustand Middleware Lab", url: "/craft/zustand-lab", year: "2026" },
	{ name: "Next.js 16 API Routes", url: "/craft/next-api", year: "2026" },
];
---

<MainLayout title="Craft">
    <section class="my-40 flex flex-col gap-3">
        <a class="text-sm tracking-wide  font-serif italic text-gray-400 dark:text-gray-500  md:fixed md:top-1/3 md:left-40 flex gap-1 hover:text-black dark:hover:text-white transition-all" href="/"> <ArrowLeft className="w-4 h-4" /> Index</a>
      <ul class="flex flex-col">
        {crafts.map((craft) => (
          <li>
            <a
              class="group flex items-center gap-2 py-3 hover:bg-gray-100 dark:hover:bg-black/30 rounded-xl px-4 transition-all"
              href={craft.url}
              target="_blank"
              rel="noopener noreferrer"
              data-scramble
            >
              <span class="font-medium whitespace-nowrap" data-scramble-text>{craft.name}</span>
              <span class="connector" data-scramble-connector></span>
              <span class="text-gray-400 dark:text-gray-500 whitespace-nowrap tabular-nums">{craft.year}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
</MainLayout>

<style>
  .connector {
    flex: 1;
    border-bottom: 1px solid currentColor;
    opacity: 0.2;
    margin-bottom: 0.2em;
    /* Empieza oculto */
    clip-path: inset(0 100% 0 0);
  }
</style>

<script>
  const CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
  const FPS = 16;
  const DECRYPT_DURATION = 1000;
  const STAGGER_DELAY = 400; // Milisegundos entre cada item

  function randomChar() {
    return CHARS[Math.floor(Math.random() * CHARS.length)];
  }

  function animateScramble(link: HTMLElement, delay: number) {
    const textEl = link.querySelector<HTMLElement>("[data-scramble-text]");
    const connector = link.querySelector<HTMLElement>("[data-scramble-connector]");
    if (!textEl) return;

    const original = textEl.textContent?.trim() ?? "";
    
    // Estado inicial: texto aleatorio
    textEl.textContent = original
      .split("")
      .map((char) => (char === " " ? " " : randomChar()))
      .join("");

    // Iniciamos la animación después del delay
    setTimeout(() => {
      const totalFrames = Math.floor(DECRYPT_DURATION / FPS);
      let frame = 0;

      // Animación del Texto
      const decryptInterval = setInterval(() => {
        const progress = frame / totalFrames;
        const resolved = Math.floor(progress * original.length);

        textEl.textContent = original
          .split("")
          .map((char, i) => {
            if (char === " ") return " ";
            if (i < resolved) return original[i];
            return randomChar();
          })
          .join("");

        frame++;

        if (frame >= totalFrames) {
          textEl.textContent = original;
          clearInterval(decryptInterval);
        }
      }, FPS);

      // Animación del Connector
      if (connector) {
        let f = 0;
        const connectorInterval = setInterval(() => {
          const progress = f / totalFrames;
          const remaining = 100 - (progress * 100);
          connector.style.clipPath = `inset(0 ${remaining}% 0 0)`;
          f++;
          if (f >= totalFrames) {
            connector.style.clipPath = "inset(0 0% 0 0)";
            clearInterval(connectorInterval);
          }
        }, FPS);
      }
    }, delay);
  }

  // Ejecutar al cargar la página
  const items = document.querySelectorAll<HTMLElement>("[data-scramble]");
  items.forEach((item, index) => {
    animateScramble(item, index * STAGGER_DELAY);
  });
</script>