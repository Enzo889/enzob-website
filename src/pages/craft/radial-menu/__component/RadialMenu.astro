---
import { Docker, Figma, Nextjs, React, Vite } from "@/components/icon";

const ITEMS = [
  { label: 'React', desc: 'Biblioteca de UI para JavaScript', tag: 'Frontend · Meta', Icon: React },
  { label: 'Vite', desc: 'Build tool de nueva generación', tag: 'Tooling · Evan You', Icon: Vite },
  { label: 'Figma', desc: 'Diseño colaborativo de interfaces', tag: 'Design · Adobe', Icon: Figma },
  { label: 'Docker', desc: 'Contenedores para apps portables', tag: 'DevOps · Docker Inc.', Icon: Docker },
  { label: 'Next.js', desc: 'Framework React full-stack', tag: 'Framework · Vercel', Icon: Nextjs },
];
---

<div class="rm-root" id="rm-root">

  <div class="rm-info hidden" id="rm-info">
    <p class="rm-name" id="rm-name"></p>
    <p class="rm-desc" id="rm-desc"></p>
    <span class="rm-tag" id="rm-tag"></span>
  </div>

  <div class="rm-wheel">
    <canvas id="rm-canvas" width="220" height="220"></canvas>
    
    <div id="rm-icons">
      {ITEMS.map((item, i) => {
        const N = ITEMS.length;
        const angle = -Math.PI / 2 + (Math.PI * 2 / N) * i;
        const dist = 69; // Radio medio entre INNER(30) y OUTER(108)
        const x = 110 + Math.cos(angle) * dist;
        const y = 110 + Math.sin(angle) * dist;
        return (
          <div 
            class="rm-icon-wrapper" 
            data-index={i}
            data-label={item.label}
            data-desc={item.desc}
            data-tag={item.tag}
            style={`left: ${x}px; top: ${y}px;`}
          >
            <item.Icon class="w-7 h-7" />
          </div>
        );
      })}
    </div>

    <div class="rm-center">
      <svg class="rm-dots" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <circle cx="5" cy="12" r="1"/>
        <circle cx="12" cy="12" r="1"/>
        <circle cx="19" cy="12" r="1"/>
      </svg>
      <span id="rm-hover-name" class="rm-hover-name"></span>
      <div id="rm-sel-container" class="rm-sel"></div>
    </div>
  </div>

  <p class="rm-hint" id="rm-hint">Hover para explorar · click para seleccionar</p>

</div>

<style>
  .rm-root {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding: 12px 0 8px;
    user-select: none;
  }

  .rm-info {
    min-height: 56px;
    text-align: center;
    transition: opacity 0.2s;
  }
  .rm-info.hidden { opacity: 0; pointer-events: none; }

  .rm-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-primary);
    margin: 0 0 3px;
  }
  .rm-desc {
    font-size: 12px;
    color: var(--color-text-secondary);
    margin: 0 0 6px;
  }
  .rm-tag {
    display: inline-block;
    font-size: 11px;
    padding: 2px 10px;
    border-radius: 999px;
    background: var(--color-background-secondary);
    border: 0.5px solid var(--color-border-secondary);
    color: var(--color-text-tertiary);
  }

  .rm-wheel {
    position: relative;
    width: 220px;
    height: 220px;
  }

  #rm-canvas {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    cursor: pointer;
    display: block;
    z-index: 1;
  }

  #rm-icons {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .rm-icon-wrapper {
    position: absolute;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rm-icon-wrapper :global(svg) {
    width: 28px;
    height: 28px;
  }

  .rm-center {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 52px; height: 52px;
    border-radius: 50%;
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 3;
  }

  .rm-dots,
  .rm-sel {
    width: 20px; height: 20px;
    position: absolute;
    transition: opacity 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rm-hover-name {
    position: absolute;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-primary);
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
    text-align: center;
    line-height: 1;
  }
  .rm-hover-name.show { opacity: 1; }

  .rm-dots { opacity: 1; }
  .rm-dots.hide { opacity: 0; }
  .rm-sel { opacity: 0; }
  .rm-sel.show { opacity: 1; }
  
  .rm-sel :global(svg) {
    width: 20px;
    height: 20px;
  }

  .rm-hint {
    font-size: 12px;
    color: var(--color-text-tertiary);
    margin: 0;
  }
</style>

<script>
  const iconWrappers = document.querySelectorAll<HTMLElement>('.rm-icon-wrapper')
  const N = iconWrappers.length
  const canvas = document.getElementById('rm-canvas') as HTMLCanvasElement
  const ctx    = canvas.getContext('2d')!
  const W = 220, CX = 110, CY = 110, OUTER = 108, INNER = 30

  const info  = document.getElementById('rm-info')!
  const iname = document.getElementById('rm-name')!
  const idesc = document.getElementById('rm-desc')!
  const itag  = document.getElementById('rm-tag')!
  const dots  = document.querySelector<SVGElement>('.rm-dots')!
  const selContainer = document.getElementById('rm-sel-container')!
  const hint  = document.getElementById('rm-hint')!
  const iconsContainer = document.getElementById('rm-icons')!
  const hoverName = document.getElementById('rm-hover-name')!

  let mode: 'menu' | 'selected' = 'menu'
  let lastIdx = -1

  function sliceAngles(i: number) {
    const s = Math.PI * 2 / N, o = -Math.PI / 2 - s / 2
    return { start: o + s * i, end: o + s * (i + 1) }
  }

  function hitTest(e: MouseEvent): number {
    const r = canvas.getBoundingClientRect()
    const x = e.clientX - r.left - CX, y = e.clientY - r.top - CY
    const d = Math.hypot(x, y)
    if (d < INNER || d > OUTER) return -1
    const a = Math.atan2(y, x), s = Math.PI * 2 / N, o = -Math.PI / 2 - s / 2
    return Math.floor((((a - o) % (Math.PI * 2)) + Math.PI * 2) % (Math.PI * 2) / s) % N
  }

  function draw(hov: number) {
    ctx.clearRect(0, 0, W, W)
    const dark = document.documentElement.classList.contains('dark')
    const bg  = dark ? 'rgba(22,22,22,.97)'    : 'rgba(248,248,248,.98)'
    const brd = dark ? 'rgba(255,255,255,.09)' : 'rgba(0,0,0,.07)'
    const hc  = dark ? 'rgba(255,255,255,.08)' : 'rgba(0,0,0,.06)'

    ctx.save(); ctx.beginPath(); ctx.arc(CX, CY, OUTER, 0, Math.PI * 2)
    ctx.fillStyle = bg; ctx.fill(); ctx.strokeStyle = brd; ctx.lineWidth = .5; ctx.stroke(); ctx.restore()

    for (let i = 0; i < N; i++) {
      const { start, end } = sliceAngles(i)
      if (i === hov) {
        ctx.save(); ctx.beginPath(); ctx.moveTo(CX, CY)
        ctx.arc(CX, CY, OUTER - .5, start, end); ctx.closePath()
        ctx.fillStyle = hc; ctx.fill(); ctx.restore()
      }
    }

    for (let i = 0; i < N; i++) {
      const { start } = sliceAngles(i)
      ctx.save(); ctx.beginPath()
      ctx.moveTo(CX + Math.cos(start) * INNER, CY + Math.sin(start) * INNER)
      ctx.lineTo(CX + Math.cos(start) * OUTER, CY + Math.sin(start) * OUTER)
      ctx.strokeStyle = brd; ctx.lineWidth = .5; ctx.stroke(); ctx.restore()
    }

    ctx.save(); ctx.globalCompositeOperation = 'destination-out'
    ctx.beginPath(); ctx.arc(CX, CY, INNER + 1, 0, Math.PI * 2)
    ctx.fillStyle = '#000'; ctx.fill(); ctx.restore()
  }

  function fadeCanvas(from: number, to: number, cb?: () => void) {
    let op = from
    const step = to > from ? 0.08 : -0.08
    const id = setInterval(() => {
      op += step
      if ((step > 0 && op >= to) || (step < 0 && op <= to)) { op = to; clearInterval(id); cb?.() }
      ctx.globalAlpha = op
      draw(lastIdx)
      iconsContainer.style.opacity = op.toString()
    }, 16)
  }

  function selectItem(idx: number) {
    mode = 'selected'
    
    const el = iconWrappers[idx]
    if (el) {
      iname.textContent = el.dataset.label || ''
      idesc.textContent = el.dataset.desc || ''
      itag.textContent  = el.dataset.tag || ''
    }
    info.classList.remove('hidden')
    hoverName.classList.remove('show')
    
    // Clonamos el icono central para mostrarlo seleccionado
    selContainer.innerHTML = ''
    const svgNode = el.querySelector('svg')
    if (svgNode) {
      selContainer.appendChild(svgNode.cloneNode(true))
    }
    
    selContainer.classList.add('show'); dots.classList.add('hide')
    hint.textContent = 'Click derecho para elegir otro'
    fadeCanvas(1, 0, () => { ctx.clearRect(0, 0, W, W); ctx.globalAlpha = 1 })
  }

  function reopenMenu() {
    mode = 'menu'; lastIdx = -1
    selContainer.classList.remove('show'); dots.classList.remove('hide')
    info.classList.add('hidden')
    hint.textContent = 'Hover para explorar · click para seleccionar'
    ctx.globalAlpha = 0; draw(-1)
    fadeCanvas(0, 1)
  }

  canvas.addEventListener('mousemove', (e) => {
    if (mode !== 'menu') return
    const idx = hitTest(e)
    if (idx !== lastIdx) {
      lastIdx = idx; draw(idx)
      if (idx >= 0) {
        const el = iconWrappers[idx]
        hoverName.textContent = el.dataset.label || ''
        hoverName.classList.add('show')
        dots.classList.add('hide')
      } else {
        hoverName.classList.remove('show')
        dots.classList.remove('hide')
      }
    }
  })

  canvas.addEventListener('mouseleave', () => {
    if (mode !== 'menu') return
    lastIdx = -1; draw(-1); 
    hoverName.classList.remove('show')
    dots.classList.remove('hide')
  })

  canvas.addEventListener('click', (e) => {
    if (mode !== 'menu') return
    const idx = hitTest(e)
    if (idx >= 0) selectItem(idx)
  })

  document.getElementById('rm-root')!.addEventListener('contextmenu', (e) => {
    e.preventDefault()
    if (mode === 'selected') reopenMenu()
  })

  draw(-1)
</script>