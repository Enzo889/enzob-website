---
---
<div class="rm-info hidden" id="rm-info">
  <p class="rm-name" id="rm-name"></p>
  <p class="rm-desc" id="rm-desc"></p>
  <span class="rm-tag" id="rm-tag"></span>
</div>

<style>
  .rm-info {
    min-height: 56px;
    text-align: center;
    transition: opacity 0.2s;
  }
  .rm-info.hidden { opacity: 0; pointer-events: none; }

  .rm-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-primary);
    margin: 0 0 3px;
  }
  .rm-desc {
    font-size: 12px;
    color: var(--color-text-secondary);
    margin: 0 0 6px;
  }
  .rm-tag {
    display: inline-block;
    font-size: 11px;
    padding: 2px 10px;
    border-radius: 999px;
    background: var(--color-background-secondary);
    border: 0.5px solid var(--color-border-secondary);
    color: var(--color-text-tertiary);
  }
</style>
