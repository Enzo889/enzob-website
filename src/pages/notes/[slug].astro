---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import { ArrowLeft } from "@/components/icon";
import MainLayout from "@/layout/MainLayout.astro";

export const getStaticPaths = (async () => {
	const notes = await getCollection("notes");
	return notes.map((note) => ({
		params: { slug: note.id },
		props: { note },
	}));
}) satisfies GetStaticPaths;

const { note } = Astro.props;
const NoteData = note.data;

const { Content, headings } = await render(note);
---

<MainLayout title={NoteData.title}>
  <!-- Table of Contents -->

  <div class="md:fixed md:top-1/3 md:left-40">
    <a href="/notes" class="text-sm tracking-wide  font-serif italic text-gray-400 dark:text-gray-500   flex gap-1 hover:text-black dark:hover:text-white transition-all"> <ArrowLeft className="w-4 h-4" /> Notes</a>
    {headings.length > 0 && (
        <div class="card ">
      <ul class="list-none mt-10">
        {headings.map((heading) => (
          <li>
            <a href={`#${heading.slug}`} class="text-sm tracking-wide  font-serif italic text-gray-400 dark:text-gray-500 flex gap-1 hover:text-black dark:hover:text-white transition-all">{heading.text}</a>
          </li>
        ))}
      </ul>
    </div>
  )}
  </div>

  <!-- Article Content -->
  <article class="prose">
    <Content />
  </article>

  <div class="mt-16 mb-8 text-center">
    <a href="#go-back" class="btn-outline btn text-sm" style="text-decoration:none;">↑ Back to Top</a>
  </div>
</MainLayout>