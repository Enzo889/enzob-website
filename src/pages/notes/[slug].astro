---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import { ArrowLeft, ArrowUp } from "@/components/icon";
import MainLayout from "@/layout/MainLayout.astro";
import { formDate } from "@/utils/formatter";

export const getStaticPaths = (async () => {
	const notes = await getCollection("notes", (note) =>
		note.id.startsWith("es/"),
	);
	return notes.map((note) => ({
		params: { slug: note.id.split("/").slice(1).join("/") },
		props: { note },
	}));
}) satisfies GetStaticPaths;

const { note } = Astro.props;
const NoteData = note.data;
const locale = Astro.currentLocale ?? "es";
const { Content, headings } = await render(note);
---

<MainLayout title={`${NoteData.title} · Enzo Bustamante`} description={NoteData.description}>
  <!-- Table of Contents -->

  <div class="md:fixed md:top-1/4 md:left-20 ">
    <a href={locale === "es" ? "/notes" : `/${locale}/notes`} class="w-fit text-sm tracking-wide font-serif italic text-text dark:text-text inline-flex gap-1 hover:text-accent dark:hover:text-accent transition-all mb-5 md:mb-0"> <ArrowLeft className="w-4 h-4" /> Notes</a>
    {headings.length > 0 && (
        <div class="w-fit hidden md:block">
      <ul class="list-none mt-10 flex flex-col">
        {headings.map((heading) => (
          <li class="mb-1">
            <a href={`#${heading.slug}`} class="w-fit text-sm tracking-wide font-serif italic text-text  hover:text-accent dark:hover:text-accent transition-all inline-block">{heading.text}</a>
          </li>
        ))}
      </ul>
    </div>
  )}
  </div>

  <header class="mb-10">
    <h1 class="text-[1.05rem]  font-body tracking-tighter text-accent">
      {NoteData.title}
    </h1>
    <p class="text-xs font-body text-text-muted mt-2">
      {formDate(NoteData.date, locale)}
    </p>
  </header>


  <!-- Article Content -->
  <article class="content">
    <Content locale={Astro.currentLocale} />
  </article >

  <a 
  id="scroll-top"
  href="#top" 
  title="Scroll to top" 
  class="fixed right-10 bottom-5 w-10 h-10 flex items-center justify-center opacity-0 pointer-events-none hover:opacity-100 rounded-full hover:bg-neutral-500/20 transition-all duration-500 z-100 print:hidden text-inherit"
>
  <ArrowUp className="w-5 h-5" />
</a>
</MainLayout>

<script>
  const scrollButton = document.getElementById('scroll-top');

  window.addEventListener('scroll', () => {
    if (!scrollButton) return;

    // Calculamos el punto medio de la página
    const scrollTotal = document.documentElement.scrollHeight - window.innerHeight;
    const scrollPosition = window.scrollY;

    // Si pasamos el 50% (0.5), mostramos el botón
    if (scrollPosition > scrollTotal * 0.5) {
      scrollButton.classList.remove('opacity-0', 'pointer-events-none');
      scrollButton.classList.add('opacity-30');
    } else {
      scrollButton.classList.add('opacity-0', 'pointer-events-none');
      scrollButton.classList.remove('opacity-30');
    }
  });
</script>


<style is:global>
  @import "tailwindcss";

  @custom-variant dark (&:where(.dark, .dark *));

  /* ── Paleta Neutral (Global) ── */
  :root {
    /* Modo Claro */
    --color-text: #646464;         
    --color-text-muted: #737373;   
    --color-surface: #ffffff;      
    --color-border: #e5e5e5;       
    --color-accent: #202020;       
    --color-accent-hover: #404040; 
    --color-secondary: #a3a3a3;
    --radius: 0.4rem;              
  }

  .dark {
    /* Modo Oscuro */
    --color-text: #b4b4b4;         
    --color-text-muted: #a3a3a3;   
    --color-surface: #0f0f0f;      
    --color-border: #262626;       
    --color-accent: #eee;       
    --color-accent-hover: #d4d4d4; 
    --color-secondary: #525252;
  }

  @layer base {
    .content {
      @apply mt-0 transition-colors duration-300;
      color: var(--color-text);
      font-family: var(--font-body);
    }

    /* ── Typography ── */

    .content h1, .content h2, .content h3 {
      @apply text-[1.05rem] my-4;
      color: var(--color-accent);
    }

    .content p {
      @apply text-[1.05rem] leading-7 my-5 opacity-90 ;
      color: var(--color-text);
    }

    .content a {
      color: var(--color-accent);
      @apply underline decoration-2 decoration-(--color-secondary) text-[1.05rem] underline-offset-4 transition-all hover:decoration-(--color-accent);
    }

    /* ── Bloques de Código (Sincronizados con Shiki Vesper) ── */
    .content pre {
      background-color: #101010 !important; /* Color exacto del tema Vesper */
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 1.25rem;
      margin: 2rem 0;
      @apply shadow-2xl;
    }

    .content code {
      font-family: 'JetBrains Mono', 'Menlo', monospace;
      @apply text-[0.9em];
    }

    /* Código inline */
    .content :not(pre) > code {
      background-color: var(--color-border);
      color: var(--color-text);
      @apply px-1.5 py-0.5 rounded text-[0.85em] font-mono border border-white/5;
    }

    /* ── Listas y Elementos ── */
    .content ul {
      @apply list-none my-6 space-y-3;
    }

    .content ul li {
      @apply relative pl-6 border-l border-(--color-border) ml-1;
    }

    /* En Vesper los puntos de lista son sutiles, eliminamos la flecha por algo más minimal */
    .content ul li::before {
      content: "";
      @apply absolute left-0 top-3 w-2 h-px bg-(--color-accent);
    }

    .content blockquote {
      @apply border-l-2 border-(--color-accent) pl-6 italic my-10 text-gray-400;
    }

    /* Tablas estilo Vesper */
    .content table {
      @apply w-full border-collapse my-8 text-sm;
    }

    .content th {
      @apply border-b border-(--color-border) text-left p-2 text-(--color-accent) font-medium;
    }

    .content td {
      @apply border-b border-(--color-border)/50 p-2 py-3;
    }
  }
</style>