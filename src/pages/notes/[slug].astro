---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import { ArrowLeft } from "@/components/icon";
import MainLayout from "@/layout/MainLayout.astro";

export const getStaticPaths = (async () => {
	const notes = await getCollection("notes");
	return notes.map((note) => ({
		params: { slug: note.id },
		props: { note },
	}));
}) satisfies GetStaticPaths;

const { note } = Astro.props;
const NoteData = note.data;

const { Content, headings } = await render(note);
---

<MainLayout title={NoteData.title}>
  <!-- Table of Contents -->

  <div class="md:fixed md:top-1/4 md:left-20 ">
    <a href="/notes" class="w-fit text-sm tracking-wide font-serif italic text-gray-400 dark:text-gray-500 inline-flex gap-1 hover:text-black dark:hover:text-white transition-all"> <ArrowLeft className="w-4 h-4" /> Notes</a>
    {headings.length > 0 && (
        <div class="w-fit">
      <ul class="list-none mt-10 flex flex-col">
        {headings.map((heading) => (
          <li class="mb-1">
            <a href={`#${heading.slug}`} class="w-fit text-sm tracking-wide font-serif italic text-gray-400 dark:text-gray-500 hover:text-black dark:hover:text-white transition-all inline-block">{heading.text}</a>
          </li>
        ))}
      </ul>
    </div>
  )}
  </div>

  <!-- Article Content -->
  <article class="content" id="top">
    <Content />
  </article >

  <div class="mt-16 mb-8 text-center">
    <a href="#top" class="btn-outline btn text-sm" style="text-decoration:none;">↑ Back to Top</a>
  </div>
</MainLayout>

<style is:global>
  @import "tailwindcss";

  @custom-variant dark (&:where(.dark, .dark *));

  /* ── Paleta Neutral (Global) ── */
  :root {
    /* Modo Claro */
    --color-text: #1a1a1a;         
    --color-text-muted: #737373;   
    --color-surface: #ffffff;      
    --color-border: #e5e5e5;       
    --color-accent: #171717;       
    --color-accent-hover: #404040; 
    --color-secondary: #a3a3a3;
    --radius: 0.4rem;              
  }

  .dark {
    /* Modo Oscuro */
    --color-text: #e5e5e5;         
    --color-text-muted: #a3a3a3;   
    --color-surface: #0f0f0f;      
    --color-border: #262626;       
    --color-accent: #ffffff;       
    --color-accent-hover: #d4d4d4; 
    --color-secondary: #525252;
  }

  @layer base {
    .content {
      @apply mt-0 transition-colors duration-300;
      color: var(--color-text);
      font-family: var(--font-body);
    }

    /* ── Typography ── */
    .content h1 {
      @apply text-4xl my-8 tracking-tighter;
      color: var(--color-accent); /* El título principal en oro */
    }

    .content h2 {
      @apply text-2xl my-6 mt-12 pb-2 border-b border-(--color-border);
      color: var(--color-text);
    }

    .content h3 {
      @apply text-xl my-4;
      color: var(--color-accent-hover);
    }

    .content p {
      @apply text-[1.05rem] leading-7 my-5 opacity-90;
    }

    .content a {
      color: var(--color-accent);
      @apply underline decoration-2 decoration-(--color-secondary) underline-offset-4 transition-all hover:decoration-(--color-accent);
    }

    /* ── Bloques de Código (Sincronizados con Shiki Vesper) ── */
    .content pre {
      background-color: #101010 !important; /* Color exacto del tema Vesper */
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 1.25rem;
      margin: 2rem 0;
      @apply shadow-2xl;
    }

    .content code {
      font-family: 'JetBrains Mono', 'Menlo', monospace;
      @apply text-[0.9em];
    }

    /* Código inline */
    .content :not(pre) > code {
      background-color: var(--color-border);
      color: var(--color-text);
      @apply px-1.5 py-0.5 rounded text-[0.85em] font-mono border border-white/5;
    }

    /* ── Listas y Elementos ── */
    .content ul {
      @apply list-none my-6 space-y-3;
    }

    .content ul li {
      @apply relative pl-6 border-l border-(--color-border) ml-1;
    }

    /* En Vesper los puntos de lista son sutiles, eliminamos la flecha por algo más minimal */
    .content ul li::before {
      content: "";
      @apply absolute left-0 top-3 w-2 h-px bg-(--color-accent);
    }

    .content blockquote {
      @apply border-l-2 border-(--color-accent) pl-6 italic my-10 text-gray-400;
    }

    /* Tablas estilo Vesper */
    .content table {
      @apply w-full border-collapse my-8 text-sm;
    }

    .content th {
      @apply border-b border-(--color-border) text-left p-2 text-(--color-accent) font-medium;
    }

    .content td {
      @apply border-b border-(--color-border)/50 p-2 py-3;
    }
  }
</style>