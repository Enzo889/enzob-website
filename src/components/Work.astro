---
import { getT } from "@/utils/i18n";

const t = getT(Astro.currentLocale ?? "es");
const works = [
	{
		name: t.work.firstJobTitle,
		url: "https://consorciovecinalsantamaria.com/",
		year: "2025",
	},
];
---

<article class="flex flex-col gap-4 my-10">
  <p class="text-sm tracking-wide uppercase font-heading text-text-muted">{t.work.title}</p>
  <ul class="flex flex-col" id="work-list">
    {works.map((work) => (
      <li>
        <a
          class="group flex items-center gap-2 py-2 md:py-3 hover:bg-border/30 rounded-xl px-3 md:px-4 transition-all"
          href={work.url}
          target="_blank"
          rel="noopener noreferrer"
          data-scramble
        >
          <span class="font-medium whitespace-nowrap text-sm md:text-base" data-scramble-text>{work.name}</span>
          <span class="connector" data-scramble-connector></span>
          <span class="text-text-muted whitespace-nowrap tabular-nums text-xs md:text-sm">{work.year}</span>
        </a>
      </li>
    ))}
  </ul>
</article>

<style>
  .connector {
    flex: 1;
    border-bottom: 1px solid currentColor;
    opacity: 0.2;
    margin-bottom: 0.2em;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.5s ease;
  }

  /* Mostrar conector por defecto en móviles o dispositivos sin hover */
  @media (hover: none) {
    .connector {
      clip-path: inset(0 0% 0 0);
    }
  }
</style>

<script>
  const CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
  const FPS = 16;
  const DECRYPT_DURATION = 800;

  function randomChar() {
    return CHARS[Math.floor(Math.random() * CHARS.length)];
  }

  function initWork() {
    const workList = document.getElementById("work-list");
    if (!workList) return;

    workList.querySelectorAll<HTMLAnchorElement>("[data-scramble]").forEach((link) => {
      const textEl = link.querySelector<HTMLElement>("[data-scramble-text]");
      const connector = link.querySelector<HTMLElement>("[data-scramble-connector]");
      if (!textEl) return;

      const original = textEl.textContent?.trim() ?? "";
      textEl.dataset.original = original;

      // Only scramble if the device supports hover
      if (window.matchMedia("(hover: hover)").matches) {
        textEl.textContent = original
          .split("")
          .map((char) => (char === " " ? " " : randomChar()))
          .join("");
      } else {
        textEl.textContent = original;
      }

      let used = false;

      link.addEventListener("mouseenter", () => {
        if (used) return;
        used = true;

        const totalFrames = Math.floor(DECRYPT_DURATION / FPS);
        let frame = 0;

        const decryptInterval = setInterval(() => {
          const progress = frame / totalFrames;
          const resolved = Math.floor(progress * original.length);

          textEl.textContent = original
            .split("")
            .map((char, i) => {
              if (char === " ") return " ";
              if (i < resolved) return original[i];
              return randomChar();
            })
            .join("");

          frame++;

          if (frame >= totalFrames) {
            textEl.textContent = original;
            clearInterval(decryptInterval);
          }
        }, FPS);

        if (connector) {
          let f = 0;
          const connectorInterval = setInterval(() => {
            const remaining = Math.round((1 - f / totalFrames) * 100);
            connector.style.clipPath = `inset(0 ${remaining}% 0 0)`;
            f++;
            if (f >= totalFrames) {
              connector.style.clipPath = "inset(0 0% 0 0)";
              clearInterval(connectorInterval);
            }
          }, FPS);
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initWork);
</script>