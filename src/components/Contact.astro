---
import { getT } from "@/utils/i18n";

const t = getT(Astro.currentLocale ?? "es");

const connect = [
	{
		name: "GitHub",
		href: "https://github.com/Enzo889",
	},
	{
		name: "LinkedIn",
		href: "https://www.linkedin.com/in/enzo-bustamante",
	},
	{
		name: "Twitter",
		href: "https://x.com/enzodev_",
	},
	{
		name: "Instagram",
		href: "https://www.instagram.com/enzo_bustamante18",
	},
	{
		name: "Email",
		href: "mailto:enzobustamante895@gmail.com",
	},
];
---

<div class="flex flex-col gap-4 my-10">
  <p class="text-sm tracking-wide uppercase font-heading text-gray-400 dark:text-gray-500">{t.contact.title}</p>
  <div class="flex flex-wrap gap-y-4 gap-x-6">
    {
      connect.map((item) => (
        <a
          class="underline text-2xl md:text-4xl leading-loose md:leading-normal underline-offset-8 hover:text-gray-500 dark:hover:text-gray-400 transition-colors"
          href={item.href}  
          target="_blank"
          rel="noopener noreferrer"
          title={item.name}
        >
          {item.name}
        </a>
      ))
    }
  </div>
</div>
