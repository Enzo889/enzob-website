---
import { getT } from "@/utils/i18n";

const t = getT(Astro.currentLocale ?? "es");

const education = [
	{
		degree: t.education.degree,
		institution: t.education.institution,
		url: "https://ies9021.edu.ar/",
		year: "2023 — 2026",
	},
];

const certificates = [
	{
		name: t.education.astro,
		url: "https://cursos.devtalles.com/certificates/j88yckkgaw",
		year: "2026",
	},
	{
		name: t.education.typescript,
		url: "https://cursos.devtalles.com/certificates/jdrawzjh4p",
		year: "2025",
	},
];
---

<article class="flex flex-col gap-10 my-10">

  <section class="edu-section flex flex-col gap-4">
    <p class="edu-label text-sm tracking-wide uppercase font-heading text-text-muted">Education</p>
    <ul class="flex flex-col gap-1">
      {education.map((item) => (
        <li class="edu-item">
          <a href={item.url} target="_blank" rel="noopener noreferrer"
            class="edu-link group relative flex items-baseline gap-2 py-3 px-4 rounded-xl overflow-hidden">
            <div class="relative flex flex-col gap-0.5 flex-1 min-w-0 z-10">
              <span title={item.degree} class="item-title font-medium text-accent truncate">{item.degree}</span>
              <span class="text-xs md:text-sm text-text-muted">{item.institution}</span>
            </div>
            <span class="connector relative z-10"></span>
            <span class="relative z-10 text-text-muted whitespace-nowrap tabular-nums text-sm">{item.year}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="edu-section flex flex-col gap-4">
    <p class="edu-label text-sm tracking-wide uppercase text-text-muted">Certificates</p>
    <ul class="flex flex-col gap-1">
      {certificates.map((item) => (
        <li class="edu-item">
          <a href={item.url} target="_blank" rel="noopener noreferrer"
            class="edu-link group relative flex items-baseline gap-2 py-3 px-4 rounded-xl overflow-hidden">
            <span title={item.name} class="item-title relative z-10 font-medium text-accent flex-1 truncate">{item.name}</span>
            <span class="connector relative z-10"></span>
            <span class="relative z-10 text-text-muted whitespace-nowrap tabular-nums text-sm">{item.year}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

</article>

<style>
  .connector {
    flex: 1;
    border-bottom: 1px solid currentColor;
    opacity: 0.12;
    margin-bottom: 0.3em;
    min-width: 1rem;
    transition: opacity 0.2s ease;
  }

  .edu-link {
    transform-style: preserve-3d;
    will-change: transform;
    /* Desactivar resaltado en móviles */
    -webkit-tap-highlight-color: transparent;
  }

  .edu-link:hover .connector { opacity: 0.4; }

  @media (hover: none) {
    .connector { opacity: 0.25; }
  }

  @media (prefers-reduced-motion: reduce) {
    .connector, .edu-link {
      transition: none !important;
    }
  }

  /* Underline elástico */
  .item-title {
    position: relative;
    display: inline-block;
  }

  .item-title::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0%;
    height: 2px;
    background: currentColor;
    opacity: 0.6;
    border-radius: 9999px;
    transform-origin: left;
    transition: width 0s;
  }

  .edu-link:hover .item-title::after {
    width: 100%;
  }

  @media (prefers-reduced-motion: reduce), (hover: none) {
    .item-title::after { display: none; }
    .edu-link { transform: none !important; }
  }
</style>

<script>
  import { animate, spring } from "motion";

  const isMobile = window.matchMedia("(hover: none)").matches;
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!isMobile && !prefersReducedMotion) {
    document.querySelectorAll<HTMLElement>(".edu-link").forEach((link) => {
      // — Tilt exagerado con spring elástico —
      link.addEventListener("mousemove", (e) => {
        const rect = link.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const nx = (e.clientX - cx) / (rect.width / 2);
        const ny = (e.clientY - cy) / (rect.height / 2);

        animate(link, {
          rotateX: -ny * 8,
          rotateY: nx * 12,
          scale: 1.03,
          x: nx * 6,
          y: ny * 3,
        }, {
          type: spring,
          stiffness: 300,
          damping: 15,
          mass: 0.5,
        });
      });

      link.addEventListener("mouseleave", () => {
        animate(link, {
          rotateX: 0,
          rotateY: 0,
          scale: 1,
          x: 0,
          y: 0,
        }, {
          type: spring,
          stiffness: 200,
          damping: 10,
          mass: 0.8,
        });
      });

      link.addEventListener("mouseup", () => {
        animate(link, {
          scale: 1.05,
          rotateZ: 0,
        }, {
          type: spring,
          stiffness: 400,
          damping: 8,
        });
      });
    });
  }
</script>