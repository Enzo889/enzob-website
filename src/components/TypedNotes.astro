---
import type { CollectionEntry } from "astro:content";
import { formDate } from "../utils/formatter";

interface Props {
	notes: CollectionEntry<"notes">;
}

const { notes } = Astro.props;
---

<a href={`/notes/${notes.id}`} class="card block" style="text-decoration:none;">
  <div class="p-5">
    <h3 class="text-lg font-semibold text-white mt-0 mb-2" style="margin-top:0;">
      {notes.data.title}
    </h3>
    <p class="text-sm mb-3" style="color: var(--color-text-muted); margin-top:0;">
      {notes.data.description}
    </p>
    <span class="text-xs" style="color: var(--color-text-dim);">
      {formDate(notes.data.date)}
    </span>
  </div>
</a>