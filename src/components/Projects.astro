---
import { getProjectsData } from "@/data/projects-data";
import { getT } from "@/utils/i18n";

const t = getT(Astro.currentLocale ?? "es");
const projects = getProjectsData(t);
---

<article class="flex flex-col gap-4 my-10">

  <div class="flex items-center justify-between">
    <p class="text-sm tracking-wide uppercase text-gray-400 dark:text-gray-500">{t.projects.title}</p>
    <a
      href="https://github.com/Enzo889"
      class="group flex items-center gap-1 text-sm text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors"
    >
      {t.projects.more}
      <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/>
      </svg>
    </a>
  </div>

  <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {projects.map((project) => (
      <li
        class="project-card  group relative border border-gray-200 dark:border-gray-800 rounded-md px-3 py-4 transition-colors hover:border-gray-400 dark:hover:border-gray-600 overflow-hidden"
      >
        <!-- Spotlight glow -->
        <div class="spotlight pointer-events-none absolute inset-0 rounded-md opacity-0 transition-opacity duration-300"></div>

        <!-- Borde iluminado -->
        <div class="spotlight-border pointer-events-none absolute inset-0 rounded-md opacity-0 transition-opacity duration-300"
          style="padding: 1px;">
        </div>

        <a href={project.link} target="_blank" rel="noopener noreferrer" class="relative flex flex-col gap-3">

          <div class="flex items-center justify-between">
            <p class="font-medium text-gray-900 dark:text-white flex items-center gap-1">
              {project.name}
              <svg class="w-3 h-3 opacity-50 transition-all group-hover:opacity-100 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M7 7h10v10"/>
              </svg>
            </p>
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors"
              onclick="event.stopPropagation()"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
            </a>
          </div>

          <p class="text-sm text-gray-400 dark:text-gray-500 truncate">{project.description}</p>

          <ul class="flex items-center gap-1 mt-1 text-xs">
            {project.stack.map((item) => (
              <li>
                <span class="badge">
                  <item.icon class="badge-icon" />
                  <p>{item.name}</p>
                </span>
              </li>
            ))}
          </ul>

        </a>
      </li>
    ))}
  </ul>

</article>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    justify-content: center;
    border: 0.1px solid #000;
    border-radius: 8px;
    padding: 0.1em 0.5em;
    background-color: #ffffff26;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  :global(.dark) .badge {
    border-color: #ffffff12;
    color: #fff;
    background-color: #ffffff12;
  }

  .badge p { color: #000; }
  :global(.dark) .badge p { color: #fff; }

  .badge-icon {
    width: 0.85em;
    height: 0.85em;
    flex-shrink: 0;
  }
</style>

<script>
  const isDark = () => document.documentElement.classList.contains("dark");

  document.querySelectorAll<HTMLLIElement>(".project-card").forEach((card) => {
    const glow = card.querySelector<HTMLDivElement>(".spotlight");

    card.addEventListener("mouseenter", () => {
      if (glow) glow.style.opacity = "1";
    });

    card.addEventListener("mouseleave", () => {
      if (glow) glow.style.opacity = "0";
    });

    card.addEventListener("mousemove", (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      if (glow) {
        const color = isDark()
          ? "rgba(255, 255, 255, 0.06)"
          : "rgba(0, 0, 0, 0.04)";
        glow.style.background = `radial-gradient(400px circle at ${x}px ${y}px, ${color}, transparent 60%)`;
      }
    });
  });
</script>