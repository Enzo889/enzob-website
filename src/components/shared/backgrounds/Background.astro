---
import Dot from "./Dot.astro";
import GridFlow from "./GridFlow.astro";
import Mesh from "./Mesh.astro";
import Particle from "./Particle.astro";
import Plum from "./Plum.astro";

interface Props {
	type: string;
}

const { type } = Astro.props;
---

{type === 'plum' && <Plum />}
{type === 'dot' && <Dot />}
{type === 'particle' && <Particle />}
{type === 'gridflow' && <GridFlow />}
{type === 'mesh' && <Mesh />}