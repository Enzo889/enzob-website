---
import { useTranslations } from "@/i18n";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);
---

<footer class="flex flex-col gap-4 mt-10">
  <hr class="border-gray-400 dark:border-gray-500 w-full" />

  <div class="flex gap-2 items-center justify-between text-sm  text-gray-400 dark:text-gray-500">

    <div class="flex justify-between w-full">
      <p>{t.footer.tagline}</p>
      <p>Enzo Bustamante © {new Date().getFullYear()} </p>
    </div>

    <!-- Reloj analógico con tooltip -->
    <div class="relative shrink-0 group" id="clock-wrapper">

      <!-- Tooltip -->
      <div
        id="clock-tooltip"
        role="tooltip"
        class="
          absolute bottom-full right-0 mb-2
          px-2 py-1
          text-xs font-mono normal-case tracking-normal whitespace-nowrap
          text-black dark:text-white
          border border-gray-400 dark:border-gray-500
          bg-white dark:bg-black
          shadow-sm
          pointer-events-none
          opacity-0 translate-y-1
          transition-all duration-150 ease-out
          group-hover:opacity-100 group-hover:translate-y-0
        "
        aria-live="polite"
      >
        --:--:-- -- GMT-3
      </div>

      <!-- Cara del reloj -->
      <div
        id="analog-clock"
        aria-label="Hora actual en Mendoza, Argentina"
        class="relative w-5 h-5 cursor-default"
        style="--h: 0; --m: 0; --s: 0;"
      >
        <!-- Borde -->
        <div class="absolute inset-0 rounded-full border border-gray-400 dark:border-gray-500 transition-colors duration-150 "></div>

        <!-- Manecilla hora -->
        <div
          class="absolute bottom-1/2 left-1/2 origin-bottom rounded-full bg-gray-400 dark:bg-gray-500 transition-colors duration-150"
          style="
            width: 1.5px;
            height: 30%;
            transform: translateX(-50%) rotate(calc(var(--h) * 30deg + var(--m) * 0.5deg));
          "
        ></div>

        <!-- Manecilla minutos -->
        <div
          class="absolute bottom-1/2 left-1/2 origin-bottom rounded-full bg-gray-400 dark:bg-gray-500 transition-colors duration-150"
          style="
            width: 1px;
            height: 38%;
            transform: translateX(-50%) rotate(calc(var(--m) * 6deg + var(--s) * 0.1deg));
          "
        ></div>

        <!-- Manecilla segundos -->
        <div
          class="absolute bottom-1/2 left-1/2 origin-bottom rounded-full bg-gray-400 dark:bg-gray-500 transition-colors duration-150"
          style="
            width: 0.75px;
            height: 42%;
            transform: translateX(-50%) rotate(calc(var(--s) * 6deg));
            transition: transform 0.3s cubic-bezier(0.4, 2.08, 0.55, 0.44), background-color 0.15s;
          "
        ></div>
      </div>

    </div>
  </div>
</footer>

<script>
  const clock   = document.getElementById("analog-clock");
  const tooltip = document.getElementById("clock-tooltip");

  // Zona horaria de Mendoza, Argentina (ART = UTC-3, no usa DST)
  const TZ = "America/Argentina/Mendoza";

  function tick() {
    const now = new Date();

    // Actualizar manecillas
    const h = now.getHours() % 12;
    const m = now.getMinutes(); 
    const s = now.getSeconds();
    clock?.style.setProperty("--h", String(h));
    clock?.style.setProperty("--m", String(m));
    clock?.style.setProperty("--s", String(s));

    // Actualizar tooltip con formato "05:00:05 PM GMT-3"
    if (tooltip) {
      const timeStr = now.toLocaleTimeString("en-US", {
        timeZone: TZ,
        hour:     "2-digit",
        minute:   "2-digit",
        second:   "2-digit",
        hour12:   true,
      });
      // toLocaleTimeString devuelve "05:00:05 AM" — agregamos GMT-3
      tooltip.textContent = `${timeStr} GMT-3`;
    }
  }

  tick();
  setInterval(tick, 1000);
</script>