---
import { useTranslations } from "@/i18n";
import ToggleMode from "./ToggleMode.astro";
import Translations from "./Translations.astro";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);
---

<nav class="flex  justify-between items-center uppercase">
    <div class="flex gap-2 text-sm">
        <p>{t.navbar.domain}</p>
        <span>/</span>
        <a href="/" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">{t.navbar.home}</a>
        <span>/</span>
        <a href="/experiments" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">{t.navbar.experiments}</a>
        <span>/</span>
        <a href="/notes" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">{t.navbar.notes}</a>
    </div>
    <div class="flex items-center  gap-2">
        <Translations />
        <ToggleMode />
    </div>
</nav>
