---
import { useTranslations } from "@/i18n";
import ToggleMode from "./ToggleMode.astro";
import Translations from "./Translations.astro";
import Logo from "./Logo.astro";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);

const pathname = new URL(Astro.request.url).pathname;

function isActive(href: string) {
	const current = pathname.replace(/\/$/, "") || "/";
	const target = href.replace(/\/$/, "") || "/";

	if (target === "/" || target === `/${locale}`) {
		return current === "/" || current === `/${locale}`;
	}
	return current.startsWith(target);
}

const links = [
	{ href: locale === "es" ? "/" : `/${locale}`, label: t.navbar.home },
	{
		href: locale === "es" ? "/craft" : `/${locale}/craft`,
		label: t.navbar.craft,
	},
	{
		href: locale === "es" ? "/notes" : `/${locale}/notes`,
		label: t.navbar.notes,
	},
];

const activeLink = links.find((l) => isActive(l.href)) ?? links[0];
---

<nav class="navbar-font flex justify-between items-center uppercase mb-8">

  <!-- Desktop -->
  <div class="hidden md:flex items-center gap-2 text-sm   ">
    <span class="font-bold text-gray-900 dark:text-white">
      <a href={locale === "es" ? "/" : `/${locale}`}>
        {t.navbar.domain}
      </a>
    </span>
    {links.map((link) => (
      <>
        <span style="color: var(--color-border)">/</span>
        <a
          href={link.href}
          class:list={[
            "tracking-wide transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-current",
          ]}
          style={isActive(link.href) 
            ? "color: var(--color-accent); font-weight: 600;" 
            : "color: var(--color-text-muted);"}
        >
          {link.label}
        </a>
      </>
    ))}
  </div>

  <!-- Mobile combobox -->
  <div class="flex md:hidden items-center gap-2 text-sm">
    <span class="font-bold">
      <a href={locale === "es" ? "/" : `/${locale}`} class="block transition-transform hover:scale-105">
        <Logo class="w-8 h-8" />
      </a>
    </span>
    <span style="color: var(--color-border)">/</span>

    <div class="relative" id="mobile-nav-wrapper">
      <!-- Trigger -->
      <button
        id="mobile-nav-trigger"
        type="button"
        role="combobox"
        aria-expanded="false"
        aria-haspopup="listbox"
        aria-autocomplete="none"
        aria-controls="mobile-nav-listbox"
        class="inline-flex items-center gap-1 bg-transparent uppercase tracking-wide text-sm font-semibold cursor-pointer focus:outline-none"
        style="color: var(--color-accent)"
      >
        <span id="mobile-nav-label">{activeLink.label}</span>
        <span aria-hidden="true" class="transition-transform duration-200" id="mobile-nav-chevron" style="width:1em;height:1em;pointer-events:none; color: var(--color-text-muted)">
          <svg display="block" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 16 16" height="1em" width="1em">
            <polyline points="4,6 8,10 12,6"></polyline>
          </svg>
        </span>
      </button>

      <!-- Dropdown -->
      <ul
        id="mobile-nav-listbox"
        role="listbox"
        aria-label="Navigation"
        class="
          absolute top-full left-0 mt-2 z-50
          border
          shadow-xl rounded-lg
          min-w-[160px]
          py-1.5
          hidden
          backdrop-blur-md
        "
        style="background-color: var(--color-surface); border-color: var(--color-border);"
      >
        {links.map((link) => (
          <li
            role="option"
            aria-selected={isActive(link.href)}
            data-href={link.href}
            class:list={[
              "px-4 py-2.5 uppercase tracking-wide text-xs cursor-pointer transition-colors",
              isActive(link.href)
                ? "font-semibold"
                : "opacity-80 hover:opacity-100",
            ]}
            style={isActive(link.href)
              ? "color: var(--color-accent); background-color: var(--color-border);"
              : "color: var(--color-text);"}
          >
            {link.label}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Controles: idioma + tema -->
  <div class="flex items-center gap-2">
    <Translations />
    <ToggleMode />
  </div>

</nav>

<style>
  .navbar-font {
    font-family: "Outfit Variable", sans-serif;
  }
</style>

<script>
  function initMobileNav() {
    const trigger  = document.getElementById("mobile-nav-trigger") as HTMLButtonElement;
    const listbox  = document.getElementById("mobile-nav-listbox") as HTMLUListElement;
    const label    = document.getElementById("mobile-nav-label") as HTMLSpanElement;
    const chevron  = document.getElementById("mobile-nav-chevron") as HTMLSpanElement;
    const wrapper  = document.getElementById("mobile-nav-wrapper") as HTMLDivElement;

    if (!trigger || !listbox || !wrapper) return;

    function open() {
      listbox.classList.remove("hidden");
      trigger.setAttribute("aria-expanded", "true");
      chevron.style.transform = "rotate(180deg)";
    }

    function close() {
      listbox.classList.add("hidden");
      trigger.setAttribute("aria-expanded", "false");
      chevron.style.transform = "rotate(0deg)";
    }

    function toggle() {
      trigger.getAttribute("aria-expanded") === "true" ? close() : open();
    }

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle();
    });

    // Navegar al hacer click en una opción
    listbox.addEventListener("click", (e) => {
      const item = (e.target as HTMLElement).closest("[data-href]") as HTMLElement | null;
      if (!item) return;
      window.location.href = item.dataset.href!;
    });

    // Cerrar al hacer click fuera
    document.addEventListener("click", (e) => {
      if (!wrapper.contains(e.target as Node)) close();
    });

    // Cerrar con Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  }

  document.addEventListener("astro:page-load", initMobileNav);
</script>