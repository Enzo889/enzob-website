<style>
.logo-svg {
  color: #000;
}

:global(.dark) .logo-svg {
  color: #fff;
}

.logo-path {
  fill: none;
  stroke: currentColor;
  stroke-width: 6;
  stroke-linejoin: round;

  /* 🔴 CLAVE: empiezan invisibles */
  stroke-dasharray: 0 1200;
  opacity: 0;

  animation: draw 10s ease forwards infinite;
}

/* Paths rojos */
.logo-path--red {
  stroke: #9F0000;
}

/* Animación */
@keyframes draw {
  0% {
    stroke-dasharray: 0 1200;
    opacity: 0;
  }

  10% {
    opacity: 1;
  }

  40% {
    stroke-dasharray: 1200 0;
  }

  85% {
    stroke-dasharray: 1200 0;
  }

  100% {
    stroke-dasharray: 0 1200;
    opacity: 1;
  }
}

/* Delay escalonado */
.logo-path:nth-child(1) { animation-delay: 0s; }
.logo-path:nth-child(2) { animation-delay: 0.4s; }
.logo-path:nth-child(3) { animation-delay: 0.8s; }
.logo-path:nth-child(4) { animation-delay: 1.2s; }
.logo-path:nth-child(5) { animation-delay: 1.6s; }
.logo-path:nth-child(6) { animation-delay: 1.8s; }
.logo-path:nth-child(7) { animation-delay: 2s; }
.logo-path:nth-child(8) { animation-delay: 2.2s; }

/* Accesibilidad */
@media (prefers-reduced-motion) {
  .logo-path {
    animation: none !important;
    stroke-dasharray: none !important;
    opacity: 1;
  }
}
</style>